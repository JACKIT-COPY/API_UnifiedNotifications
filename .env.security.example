# ==========================================
# SECURITY CONFIGURATION
# ==========================================

# CORS - Restrict which domains can access your API
ALLOWED_ORIGINS=https://your-frontend.com,https://app.lancolatech.co.ke

# Rate Limiting - Prevent abuse
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100

# API Key Authentication (Optional)
API_KEY_REQUIRED=true
API_KEY_HEADER=X-API-Key

# IP Whitelist (Optional - comma separated)
ALLOWED_IPS=162.243.190.66,your.office.ip

# Request Size Limits
MAX_REQUEST_SIZE=25mb

# Helmet Security Headers
HELMET_ENABLED=true

# Additional JWT Security
JWT_REFRESH_SECRET=your_refresh_token_secret
JWT_REFRESH_EXPIRES_IN=30d
