# ==========================================
# PRODUCTION ENVIRONMENT VARIABLES
# ==========================================
# Copy this file to .env on your production server
# Update all values marked with "changeme" or "your_"
# ==========================================

# ==========================================
# DATABASE CONFIGURATION
# ==========================================
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme_use_strong_random_password_here
MONGO_DATABASE=unified_api

# Note: In Docker, this connects to the mongodb service
MONGODB_URI=mongodb://admin:changeme_use_strong_random_password_here@mongodb:27017/unified_api?authSource=admin

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
NODE_ENV=production
PORT=3040

# ==========================================
# JWT AUTHENTICATION
# ==========================================
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=changeme_generate_random_64_character_secret
JWT_EXPIRES_IN=7d

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password
MAIL_FROM=noreply@lancolatech.co.ke
MAIL_FROM_NAME=Lancola Tech Notifications

# ==========================================
# SMS CONFIGURATION
# ==========================================
SMS_API_URL=https://api.lancolasms.com/v1
SMS_API_KEY=your_actual_sms_api_key
SMS_SENDER_ID=LANCOLA

# ==========================================
# WHATSAPP CONFIGURATION
# ==========================================
WHATSAPP_API_URL=https://graph.facebook.com/v17.0
WHATSAPP_API_KEY=your_whatsapp_business_api_token
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id

# ==========================================
# CORS CONFIGURATION
# ==========================================
FRONTEND_URL=https://sms.lancolatech.co.ke
ALLOWED_ORIGINS=https://sms.lancolatech.co.ke,https://api.sms.lancolatech.co.ke

# ==========================================
# SESSION CONFIGURATION
# ==========================================
SESSION_SECRET=changeme_another_random_secret_for_sessions

# ==========================================
# LOGGING & MONITORING
# ==========================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# ==========================================
# SECURITY
# ==========================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
