# ==========================================
# DATABASE CONFIGURATION
# ==========================================
MONGO_ROOT_USERNAME=admin
MONGO_ROOT_PASSWORD=changeme_secure_mongodb_password
MONGO_DATABASE=unified_api
MONGODB_URI=mongodb://admin:changeme_secure_mongodb_password@localhost:27017/unified_api?authSource=admin

# ==========================================
# APPLICATION CONFIGURATION
# ==========================================
NODE_ENV=production
PORT=3040

# ==========================================
# JWT AUTHENTICATION
# ==========================================
JWT_SECRET=changeme_very_secure_jwt_secret_at_least_32_characters_long
JWT_EXPIRES_IN=7d

# ==========================================
# EMAIL CONFIGURATION
# ==========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=your_email@gmail.com
MAIL_PASSWORD=your_app_specific_password
MAIL_FROM=noreply@lancolatech.co.ke
MAIL_FROM_NAME=Unified Notifications API

# ==========================================
# SMS CONFIGURATION (Lancola SMS)
# ==========================================
SMS_API_URL=https://api.lancolasms.com/v1
SMS_API_KEY=your_sms_api_key
SMS_SENDER_ID=LANCOLA

# ==========================================
# WHATSAPP CONFIGURATION
# ==========================================
WHATSAPP_API_URL=https://api.whatsapp.com/v1
WHATSAPP_API_KEY=your_whatsapp_api_key
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id

# ==========================================
# CORS CONFIGURATION
# ==========================================
FRONTEND_URL=https://your-frontend-domain.com
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-frontend-domain.com

# ==========================================
# SESSION CONFIGURATION
# ==========================================
SESSION_SECRET=changeme_session_secret_key

# ==========================================
# OPTIONAL: LOGGING & MONITORING
# ==========================================
LOG_LEVEL=info
ENABLE_REQUEST_LOGGING=true

# ==========================================
# OPTIONAL: FILE UPLOAD
# ==========================================
MAX_FILE_SIZE=25mb
UPLOAD_DIR=/tmp/uploads

# ==========================================
# OPTIONAL: RATE LIMITING
# ==========================================
RATE_LIMIT_TTL=60
RATE_LIMIT_MAX=100
